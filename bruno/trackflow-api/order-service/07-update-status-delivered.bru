meta {
  name: Update Status - DELIVERED
  type: http
  seq: 7
}

patch {
  url: {{order_service_url}}/api/v1/orders/{{order_id}}/status
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "DELIVERED",
    "notes": "Entregue ao destinatário"
  }
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Order status updated", function() {
    expect(res.body.status).to.equal("DELIVERED");
  });
}
